# ============================================================================
# ENVIRONMENT BLUEPRINT — AURA
# Copy to `.env.local` for local dev. Add the same keys in Vercel project
# settings (Settings -> Environment Variables) for Preview + Production.
# ============================================================================

# ---- DATA SOURCE TOGGLE -----------------------------------------------------
# "mock" = in-memory array (default). "supabase" = live cloud DB.
# Flip to supabase for the final review with ZERO code changes.
DATA_SOURCE=mock

# ============================================================================
# SERVER-ONLY SECRETS  (no NEXT_PUBLIC_ prefix)
# These are NEVER bundled into client JS. They exist only inside the
# serverless functions at /api/*. Leaking any of these is a security incident.
# ============================================================================

# Anthropic — read only by app/api/stylist/route.ts
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role — bypasses Row Level Security. Server only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# CLIENT-SAFE PUBLIC VARS  (NEXT_PUBLIC_ prefix)
# Inlined into the browser bundle at build time. Put ONLY non-sensitive,
# publicly shareable values here. The anon key is safe ONLY because RLS
# policies restrict what it can read/write.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_APP_NAME=AURA
